---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<footer class="bg-fern-text text-green-200 px-5 py-12">
  <div class="max-w-6xl mx-auto grid md:grid-cols-4 gap-8 mb-8">
    <div class="md:col-span-1">
      <div class="inline-block bg-white rounded-2xl p-3 mb-4">
        <img src={`${base}/design-ref/logoHerFrequency.png`} alt="Her Frequency" class="h-16 w-auto" style="mix-blend-mode:multiply;" />
      </div>
      <p class="text-green-400 text-xs leading-relaxed">
        High-energy hub for women in STEM. Career excellence meets biological science.
      </p>
    </div>
    <div>
      <p class="text-xs font-bold uppercase tracking-widest text-green-400 mb-3">Journal</p>
      <ul class="space-y-2 text-xs text-green-600">
        <li><a href={`${base}#journal`} class="hover:text-fern-pale transition-colors">Biological Cycles</a></li>
        <li><a href={`${base}#journal`} class="hover:text-fern-pale transition-colors">Corporate Empowerment</a></li>
        <li><a href={`${base}#stem`}    class="hover:text-fern-pale transition-colors">STEM Progression</a></li>
        <li><a href={`${base}#stem`}    class="hover:text-fern-pale transition-colors">Energy Sector</a></li>
      </ul>
    </div>
    <div>
      <p class="text-xs font-bold uppercase tracking-widest text-green-400 mb-3">Community</p>
      <ul class="space-y-2 text-xs text-green-600">
        <li><a href={`${base}#collective`} class="hover:text-fern-pale transition-colors">The Collective</a></li>
        <li><a href={`${base}#collective`} class="hover:text-fern-pale transition-colors">Mentorship</a></li>
        <li><a href={`${base}#events`}     class="hover:text-fern-pale transition-colors">Events</a></li>
        <li><a href={`${base}#newsletter`} class="hover:text-fern-pale transition-colors">Newsletter</a></li>
      </ul>
    </div>
    <div>
      <p class="text-xs font-bold uppercase tracking-widest text-green-400 mb-3">About</p>
      <ul class="space-y-2 text-xs text-green-600">
        <li><a href="#" class="hover:text-fern-pale transition-colors">Mission</a></li>
        <li><a href="#" class="hover:text-fern-pale transition-colors">Research</a></li>
        <li><a href="#" class="hover:text-fern-pale transition-colors">Contact</a></li>
        <li><a href="#" class="hover:text-fern-pale transition-colors">Privacy</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-green-900 pt-6 flex flex-col md:flex-row items-center justify-between gap-3">
    <p class="text-green-700 text-xs">© 2026 Her Frequency. All rights reserved.</p>
    <p class="text-green-700 text-xs">Evidence-based. No compromise.</p>
  </div>
</footer>
